{
  "name": "waichat",
  "main": "src/worker/index.ts",
  "compatibility_date": "2025-10-01",
  "compatibility_flags": ["nodejs_compat"],
  // Built React app served as static assets
  "assets": {
    "directory": "./dist"
  },
  // Workers AI binding — remote = true suppresses the local proxy warning
  "ai": {
    "binding": "AI",
    "remote": true
  },
  // D1 Database — replace with your actual database_id from `wrangler d1 create waichat-db`
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "waichat-db",
      "database_id": "your-database-id-here",
      "migrations_dir": "migrations"
    }
  ]
}
